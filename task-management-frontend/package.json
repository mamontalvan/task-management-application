{
  "name": "nestjs-course-frontend",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@emotion/react": "^11.11.0",
    "@emotion/styled": "^11.11.0",
    "@mui/material": "^5.14.0",
    "@mui/icons-material": "^5.14.0",
    "axios": "^1.6.0",
    "mobx": "^6.10.0",
    "mobx-react": "^9.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router": "^6.20.0",
    "react-router-dom": "^6.20.0",
    "react-scripts": "5.0.1",
    "rxjs": "^7.8.0",
    "sass": "^1.69.0",
    "styled-components": "^6.1.0",
    "typescript": "^5.3.0",
    "query-string": "^8.1.0"
  },
  "scripts": {
    "start": "cross-env PORT=3001 react-app-rewired start",
    "build": "cross-env react-app-rewired build",
